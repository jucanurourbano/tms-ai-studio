# === Aplicación ===
APP_NAME=TMS AI Studio
APP_ENV=development
API_V1_PREFIX=/api/v1

# === Anthropic / Claude ===
# Dejar VACÍA en desarrollo y tests: siempre se usan mocks (ver CLAUDE.md).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_TIMEOUT=180
CLAUDE_PRICE_INPUT_PER_MTOK=3
CLAUDE_PRICE_OUTPUT_PER_MTOK=15

# === Infraestructura (contenedores docker-compose) ===
DATABASE_URL=postgresql+asyncpg://tms:tms_dev_password@localhost:5432/tms_ai_studio
REDIS_URL=redis://localhost:6379/0

# === Agente Scrum ===
SCRUM_SPRINT_CAPACITY=20
SCRUM_COVERAGE_THRESHOLD=1.0

# === Integración ClickUp (cuenta COMPARTIDA — guard fail-closed) ===
# Dejar VACÍO desactiva toda escritura (fail-closed). El agente SOLO opera dentro
# del espacio de Sistemas: la allowlist de listas es obligatoria para escribir.
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_SPACE_ID=
CLICKUP_FOLDER_ID=
CLICKUP_ALLOWED_LIST_IDS=[]
CLICKUP_DRY_RUN=true

# === Autenticación (JWT) ===
# Genera un secret fuerte, p. ej.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# En PRODUCCIÓN debe ser único, secreto y rotarse periódicamente.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# === CORS (desarrollo: abierto) ===
CORS_ORIGINS=["*"]
